{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Statusquote Quote Pack",
  "description": "Schema for a statusquote franchise or character quote pack",
  "type": "object",
  "required": ["name", "key", "verbs", "phrases", "metadata"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "maxLength": 50,
      "description": "Human-readable franchise name"
    },
    "key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*$",
      "maxLength": 30,
      "description": "Lowercase alphanumeric identifier used in commands"
    },
    "verbs": {
      "type": "array",
      "minItems": 10,
      "maxItems": 25,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 50,
        "pattern": "^[A-Za-z0-9 ',.!?-]+$"
      },
      "description": "Gerund-style spinner words (e.g. Engaging, Scanning)"
    },
    "phrases": {
      "type": "array",
      "minItems": 10,
      "maxItems": 30,
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 50,
        "pattern": "^[A-Za-z0-9 ',.!?-]+$"
      },
      "description": "Short quote phrases (e.g. Make it so, Fascinating)"
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9]*$", "maxLength": 10 },
      "description": "Short alternative keys (e.g. bttf for backtothefuture)"
    },
    "type": {
      "type": "string",
      "enum": ["franchise", "character"],
      "description": "Pack category"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z]+$" },
      "description": "Genre/category tags for group selection (e.g. scifi, fantasy, comedy)"
    },
    "metadata": {
      "type": "object",
      "required": ["source", "contributor"],
      "properties": {
        "source": { "type": "string" },
        "contributor": { "type": "string" }
      }
    }
  }
}
